    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: ???
    text: Sheesh I thought you were already a goner...
    portrait: {fileID: 21300000, guid: 725ae35eec287b445a46259bfbf2c077, type: 3}
    clearPortraitIfNone: 0
    emotion: 4
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: ???
    text: So stranger... What brings you here today?
