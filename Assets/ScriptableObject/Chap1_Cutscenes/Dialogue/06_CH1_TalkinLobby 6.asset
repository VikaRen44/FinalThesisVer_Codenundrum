  lines:
  - speakerName: Lizzy
    text: WHO TOLD YOU TO ENTER MY ROOM!?
    portrait: {fileID: 21300000, guid: 058852535d19516498544db2cd8aee63, type: 3}
    clearPortraitIfNone: 0
    emotion: 3
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: hey dont get mad at us. We only did what you asked!
    portrait: {fileID: 21300000, guid: 725ae35eec287b445a46259bfbf2c077, type: 3}
    clearPortraitIfNone: 0
    emotion: 4
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: Well you-
    portrait: {fileID: 21300000, guid: 058852535d19516498544db2cd8aee63, type: 3}
    clearPortraitIfNone: 0
    emotion: 3
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: ...
    portrait: {fileID: 21300000, guid: 058852535d19516498544db2cd8aee63, type: 3}
    clearPortraitIfNone: 0
    emotion: 3
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: ...
    portrait: {fileID: 21300000, guid: 177e0a6c25dadd949a094668e55c8a7b, type: 3}
    clearPortraitIfNone: 0
    emotion: 1
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: Sigh...
    portrait: {fileID: 21300000, guid: 177e0a6c25dadd949a094668e55c8a7b, type: 3}
    clearPortraitIfNone: 0
    emotion: 1
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: 'Fine... Ill let it slide... '
    portrait: {fileID: 21300000, guid: 177e0a6c25dadd949a094668e55c8a7b, type: 3}
    clearPortraitIfNone: 0
    emotion: 1
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: Lets move on to your next task
    portrait: {fileID: 21300000, guid: 177e0a6c25dadd949a094668e55c8a7b, type: 3}
    clearPortraitIfNone: 0
    emotion: 1
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: There are some doors in the house that i cant access...
    portrait: {fileID: 21300000, guid: 177e0a6c25dadd949a094668e55c8a7b, type: 3}
    clearPortraitIfNone: 0
    emotion: 1
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: Some kind of wiring problem made them unable to open...
    portrait: {fileID: 21300000, guid: 177e0a6c25dadd949a094668e55c8a7b, type: 3}
    clearPortraitIfNone: 0
    emotion: 1
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: Fix the first door located in the hallway connecting the lobby and the
      kitchen
    portrait: {fileID: 21300000, guid: 177e0a6c25dadd949a094668e55c8a7b, type: 3}
    clearPortraitIfNone: 0
    emotion: 1
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: Just... Fix that and then call for me...
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 4
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: A-alright then...
    portrait: {fileID: 21300000, guid: 725ae35eec287b445a46259bfbf2c077, type: 3}
    clearPortraitIfNone: 0
    emotion: 4
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
