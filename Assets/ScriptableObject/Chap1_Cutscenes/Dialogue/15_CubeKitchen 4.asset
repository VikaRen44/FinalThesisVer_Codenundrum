%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d1af1a120e61d4046b725d4bf4f573bf, type: 3}
  m_Name: 15_CubeKitchen 4
  m_EditorClassIdentifier: Assembly-CSharp::SimpleDialogueSequenceSO
  defaultTypingSfx: {fileID: 8300000, guid: 41c6af3979137354d8337f0d8b3c3e28, type: 3}
  defaultTypingSfxVolume: 0.4
  multiplyTypingByMasterVolume: 1
  multiplyTypingByAudioListenerVolume: 0
  masterVolumePrefsKey: settings_masterVolume
  autoCreateMasterPrefsKeyIfMissing: 1
  defaultMasterVolumeIfMissing: 1
  tutorialBeforeDialogue: {fileID: 0}
  tutorialAfterDialogue: {fileID: 0}
  tutorialLinksPerLine: []
  autoAdvanceByDefault: 0
  defaultAutoAdvanceSeconds: 0.8
  allowSkipAutoAdvanceWait: 1
  lines:
  - speakerName: Lizzy
    text: Papa... I remember now! Thank you! Thank you for saving me!
    portrait: {fileID: 21300000, guid: d4b0b770c49fe974caff9f4d46053ef8, type: 3}
    clearPortraitIfNone: 0
    emotion: 4
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: 
    text: '*Lizzy composes herself and turns to the both of you'
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 4
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: 
    text: ...
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: 
    text: ...
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: 
    text: ...
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: 'I guess I owe you two my thanks '
    portrait: {fileID: 21300000, guid: 470654cee0b483e4d9c07b53bbe4e93b, type: 3}
    clearPortraitIfNone: 0
    emotion: 2
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: We're glad that you finally confronted your past Lizzy.
    portrait: {fileID: 21300000, guid: 3697e1d2fc2adcc48ba23a4aa5c8778e, type: 3}
    clearPortraitIfNone: 0
    emotion: 2
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: Yeah! I don't know how to explain it but I feel lighter now. Like a huge
      burden had just been lifted.
    portrait: {fileID: 21300000, guid: 470654cee0b483e4d9c07b53bbe4e93b, type: 3}
    clearPortraitIfNone: 0
    emotion: 2
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: Hey look!
    portrait: {fileID: 21300000, guid: bdf2c20617b352b4b99709ee0df5c6f5, type: 3}
    clearPortraitIfNone: 0
    emotion: 5
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: 
    text: '*A portal opens back to the DataSpace'
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 5
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: 'Lizzy '
    text: I guess you two weren't lying after all
    portrait: {fileID: 21300000, guid: bdf2c20617b352b4b99709ee0df5c6f5, type: 3}
    clearPortraitIfNone: 1
    emotion: 5
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: 'Lizzy '
    text: Well enough of that... I believe you still have a lot of worlds to go through
    portrait: {fileID: 21300000, guid: 177e0a6c25dadd949a094668e55c8a7b, type: 3}
    clearPortraitIfNone: 1
    emotion: 2
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: 'Lizzy '
    text: Stay safe both of you! and do visit from time to time!
    portrait: {fileID: 21300000, guid: 470654cee0b483e4d9c07b53bbe4e93b, type: 3}
    clearPortraitIfNone: 1
    emotion: 2
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: You too Lizzy! Take care of yourself!
    portrait: {fileID: 21300000, guid: 3697e1d2fc2adcc48ba23a4aa5c8778e, type: 3}
    clearPortraitIfNone: 1
    emotion: 2
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
