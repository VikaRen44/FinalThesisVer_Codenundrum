%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d1af1a120e61d4046b725d4bf4f573bf, type: 3}
  m_Name: 02_CH1_Entry
  m_EditorClassIdentifier: Assembly-CSharp::SimpleDialogueSequenceSO
  defaultTypingSfx: {fileID: 8300000, guid: 41c6af3979137354d8337f0d8b3c3e28, type: 3}
  defaultTypingSfxVolume: 0.4
  multiplyTypingByMasterVolume: 1
  multiplyTypingByAudioListenerVolume: 0
  masterVolumePrefsKey: settings_masterVolume
  autoCreateMasterPrefsKeyIfMissing: 1
  defaultMasterVolumeIfMissing: 1
  tutorialBeforeDialogue: {fileID: 0}
  tutorialAfterDialogue: {fileID: 0}
  tutorialLinksPerLine: []
  autoAdvanceByDefault: 0
  defaultAutoAdvanceSeconds: 0.8
  allowSkipAutoAdvanceWait: 1
  lines:
  - speakerName: Mouse
    text: Seems his computer seems likes it hasn't been used for a while.
    portrait: {fileID: 21300000, guid: 187bbd1323ce2ba45a31e48f24dfdac6, type: 3}
    clearPortraitIfNone: 0
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: Look at how thick the dust has accumulated!
    portrait: {fileID: 21300000, guid: 725ae35eec287b445a46259bfbf2c077, type: 3}
    clearPortraitIfNone: 0
    emotion: 5
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: 
    text: '*You boot up the computer. Luckily it doesn''t have a password.'
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: Wait! look at this!
    portrait: {fileID: 21300000, guid: 3697e1d2fc2adcc48ba23a4aa5c8778e, type: 3}
    clearPortraitIfNone: 1
    emotion: 5
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: Life 3.0, Handbook into Robotics, Mechanisms of Automata...
    portrait: {fileID: 21300000, guid: 187bbd1323ce2ba45a31e48f24dfdac6, type: 3}
    clearPortraitIfNone: 0
    emotion: 5
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: The people who lived here must have been doing some projects involving
      robots!
    portrait: {fileID: 21300000, guid: 187bbd1323ce2ba45a31e48f24dfdac6, type: 3}
    clearPortraitIfNone: 0
    emotion: 5
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: That explains why there's a lot of mechanical stuff around the house.
    portrait: {fileID: 21300000, guid: 187bbd1323ce2ba45a31e48f24dfdac6, type: 3}
    clearPortraitIfNone: 0
    emotion: 5
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: 
    text: '*You continue to browse the computer a bit more but both of you suddenly
      hear something...'
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: 
    text: THUD!!!
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: Huh? What was that!?
    portrait: {fileID: 21300000, guid: 725ae35eec287b445a46259bfbf2c077, type: 3}
    clearPortraitIfNone: 1
    emotion: 5
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
