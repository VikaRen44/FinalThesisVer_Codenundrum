  lines:
  - speakerName: Lizzy
    text: Hey you found it!
    portrait: {fileID: 21300000, guid: bdf2c20617b352b4b99709ee0df5c6f5, type: 3}
    clearPortraitIfNone: 0
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: I....Remember.... my father....
    portrait: {fileID: 0}
    clearPortraitIfNone: 0
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: He tried to save me but... I don't know what happened next...
    portrait: {fileID: 0}
    clearPortraitIfNone: 0
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: 
    text: ...
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: The last Memory Cube is inside his old laboratory...
    portrait: {fileID: 0}
    clearPortraitIfNone: 0
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: 'You need to unlock the door under the stairs in the lobby... '
    portrait: {fileID: 21300000, guid: 177e0a6c25dadd949a094668e55c8a7b, type: 3}
    clearPortraitIfNone: 0
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Lizzy
    text: You know what to do...
    portrait: {fileID: 21300000, guid: 177e0a6c25dadd949a094668e55c8a7b, type: 3}
