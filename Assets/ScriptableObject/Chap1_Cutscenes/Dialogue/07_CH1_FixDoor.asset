  tutorialLinksPerLine: []
  autoAdvanceByDefault: 0
  defaultAutoAdvanceSeconds: 0.8
  allowSkipAutoAdvanceWait: 1
  lines:
  - speakerName: Mouse
    text: You know...
    portrait: {fileID: 21300000, guid: 187bbd1323ce2ba45a31e48f24dfdac6, type: 3}
    clearPortraitIfNone: 0
    emotion: 3
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: I kinda fell bad for her...
    portrait: {fileID: 21300000, guid: 725ae35eec287b445a46259bfbf2c077, type: 3}
    clearPortraitIfNone: 0
    emotion: 3
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: She's been by her own for who knows how long...
    portrait: {fileID: 21300000, guid: 187bbd1323ce2ba45a31e48f24dfdac6, type: 3}
    clearPortraitIfNone: 0
    emotion: 3
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: Makes you wonder how was she able to keep herself company...
    portrait: {fileID: 21300000, guid: 725ae35eec287b445a46259bfbf2c077, type: 3}
    clearPortraitIfNone: 0
    emotion: 3
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: Well... At the very least we are here helping her with her chores.
    portrait: {fileID: 21300000, guid: 187bbd1323ce2ba45a31e48f24dfdac6, type: 3}
    clearPortraitIfNone: 0
    emotion: 3
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: Even though it ain't that much...
    portrait: {fileID: 21300000, guid: 187bbd1323ce2ba45a31e48f24dfdac6, type: 3}
    clearPortraitIfNone: 0
    emotion: 3
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: ...
    portrait: {fileID: 21300000, guid: 187bbd1323ce2ba45a31e48f24dfdac6, type: 3}
    clearPortraitIfNone: 0
    emotion: 3
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: ...
    portrait: {fileID: 21300000, guid: 187bbd1323ce2ba45a31e48f24dfdac6, type: 3}
    clearPortraitIfNone: 0
    emotion: 3
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: Anyway!
    portrait: {fileID: 21300000, guid: 3697e1d2fc2adcc48ba23a4aa5c8778e, type: 3}
    clearPortraitIfNone: 0
    emotion: 2
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: She said these iron doors have some kind of wiring issues
    portrait: {fileID: 21300000, guid: 187bbd1323ce2ba45a31e48f24dfdac6, type: 3}
    clearPortraitIfNone: 0
    emotion: 2
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
  - speakerName: Mouse
    text: 'Lets take a look! '
    portrait: {fileID: 21300000, guid: 3697e1d2fc2adcc48ba23a4aa5c8778e, type: 3}
    clearPortraitIfNone: 0
    emotion: 2
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: -1
