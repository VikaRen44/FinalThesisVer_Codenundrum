  allowSkipAutoAdvanceWait: 1
  lines:
  - speakerName: 
    text: "System: \u26A0 CRITICAL CONDITION DETECTED-Vital parameters destabilizing.\r\n"
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "Elisabeth: HAAH! HAHH! Papa\u2026 it hurts!"
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: 'Father: PLEASE STAY WITH ME ELISABETH PAPA IS HERE! JUST FOCUS ON MY VOICE!'
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "System: \u26A0 CRITICAL CONDITION DETECTED-Vital parameters destabilizing.\r\n"
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: 'System: Heart rate exceeding maximum tolerance.

      Oxygen saturation
      dropping rapidly.'
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: 'System: Neural activity desynchronizing.

      Cognitive signal degradation
      accelerating.'
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: 'System: Multi-organ failure predicted.'
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "Father: No\u2026 no\u2026 This isn\u2019t working\u2014 Her body can\u2019t
      take it\u2014"
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: 'System: Consciousness fragmentation detected. Neural patterns destabilizing
      beyond biological recovery.'
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "Father: Wait\u2026 Her neural patterns\u2014 They\u2019re still intact\u2026"
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "Father: If I can isolate her consciousness\u2014If I can move it somewhere
      stable\u2014"
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "System: \u26A0 BIOLOGICAL SHELL FAILURE: IRREVERSIBLE"
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: 'System: Estimated time to cardiac arrest: 00:32'
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "Elisabeth: Papa\u2026 I\u2019m scared\u2026"
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "Father: I know\u2026 I know\u2026 But listen to me, sweetheart."
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "Father: Papa won\u2019t let you disappear."
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "System: \u26A0 NEURAL TRANSFER PROTOCOL \u2014 UNAUTHORIZED ACCESS DETECTED\r\n"
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: 'System: Initiating consciousness mapping. Synaptic structure being digitized.'
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: 'System: WARNING: Biological body will not survive procedure.'
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "Father: I\u2019m sorry\u2026 I\u2019m so sorry\u2026\r\nThis is the only
      way\u2026"
    portrait: {fileID: 21300000, guid: 0c3160f918a05d743ad1e0f1a4c1b7e1, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: 
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "System: \u26A0 CONSCIOUSNESS TRANSFER IN PROGRESS"
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "System: Neural pattern stabilization\u2026 Memory core preserved."
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: 'System: Biological vitals lost.'
    portrait: {fileID: 0}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
