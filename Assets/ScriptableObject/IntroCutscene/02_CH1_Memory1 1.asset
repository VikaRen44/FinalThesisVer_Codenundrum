--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d1af1a120e61d4046b725d4bf4f573bf, type: 3}
  m_Name: 02_CH1_Memory1 1
  m_EditorClassIdentifier: Assembly-CSharp::SimpleDialogueSequenceSO
  defaultTypingSfx: {fileID: 8300000, guid: 41c6af3979137354d8337f0d8b3c3e28, type: 3}
  defaultTypingSfxVolume: 0.4
  multiplyTypingByMasterVolume: 1
  multiplyTypingByAudioListenerVolume: 0
  masterVolumePrefsKey: settings_masterVolume
  autoCreateMasterPrefsKeyIfMissing: 1
  defaultMasterVolumeIfMissing: 1
  tutorialBeforeDialogue: {fileID: 0}
  tutorialAfterDialogue: {fileID: 0}
  tutorialLinksPerLine: []
  autoAdvanceByDefault: 1
  defaultAutoAdvanceSeconds: 4
  allowSkipAutoAdvanceWait: 1
  lines:
  - speakerName: 
    text: 'Father: How are you doing today Elisabeth?'
    portrait: {fileID: 21300000, guid: 723163fc6af13fd4fade6007ed1c3d3c, type: 3}
    clearPortraitIfNone: 0
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "Elisabeth: Im\u2026 Im doing much better papa. "
    portrait: {fileID: 21300000, guid: 723163fc6af13fd4fade6007ed1c3d3c, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "Elisabeth: Please\u2026 Can you stay with me today? "
    portrait: {fileID: 21300000, guid: 723163fc6af13fd4fade6007ed1c3d3c, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "Father: I\u2026 I can\u2019t sweetie. Papa has to go to work."
    portrait: {fileID: 21300000, guid: 723163fc6af13fd4fade6007ed1c3d3c, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: 'Father: Papa is working on a cure to get you all better.'
    portrait: {fileID: 21300000, guid: 723163fc6af13fd4fade6007ed1c3d3c, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: 'Father: After you get all better, we can go and play outside again, as
      much as you want!'
    portrait: {fileID: 21300000, guid: 723163fc6af13fd4fade6007ed1c3d3c, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: "Elisabeth: hehe\u2026 I can\u2019t wait to get better soon papa\u2026"
    portrait: {fileID: 21300000, guid: 723163fc6af13fd4fade6007ed1c3d3c, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: 'Father: Me too sweetie.'
    portrait: {fileID: 21300000, guid: 723163fc6af13fd4fade6007ed1c3d3c, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
  - speakerName: 
    text: 'Father: Now get some rest my sweet little troublemaker.'
    portrait: {fileID: 21300000, guid: 723163fc6af13fd4fade6007ed1c3d3c, type: 3}
    clearPortraitIfNone: 1
    emotion: 0
    typingSfxOverride: {fileID: 0}
    typingSfxVolume: 0
    choices: []
    autoAdvanceSeconds: 0
