  m_Script: {fileID: 11500000, guid: 24a696b41c0924b448a55cbfbb0baf54, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BranchChoice
  dialogueManager: {fileID: 1166681350}
  choiceADialogue:
  - speaker: Mouse
    portraitName: Mouse_Excited
    text: How nice of you!
    backgroundName: 
  - speaker: Mouse
    portraitName: Mouse_Neutral
    text: ' I saw a box labeled "Props <3" when we were organizing the boxes earlier.
      We could help her sort those next. '
    backgroundName: 
  - speaker: Mouse
    portraitName: Mouse_Excited
    text: 'It''ll lift some of the nervousness she has right now. '
    backgroundName: 
  choiceBDialogue:
  - speaker: Faith
    portraitName: Confused_Faith
    text: Hm? What now?
    backgroundName: 
  - speaker: Mouse
    portraitName: Mouse_Sad
    text: 'Uhh.. Sorry. My friend here is simply very keen on helping you move in
      your new place.  '
    backgroundName: 
  - speaker: Mouse
    portraitName: Mouse_Angry
    text: They just can't control their impulses.
    backgroundName: 
  - speaker: Faith
    portraitName: Faith_cropped
    text: ' It''s cool. We''re done with organizing the pages of scripts anyway.  '
    backgroundName: 
  - speaker: Mouse
    portraitName: Mouse_Surprised
    text: 'Yeah, but- '
    backgroundName: 
  - speaker: Faith
    portraitName: Faith_cropped
    text: Let's go organize the props next!
    backgroundName: 
  choiceAButton: {fileID: 2138615470}
  choiceBButton: {fileID: 1620953487}
  loadSceneAfterChoice: 0
  sceneForChoiceA: 04_True_heap
  sceneForChoiceB: 06_QuickSort
