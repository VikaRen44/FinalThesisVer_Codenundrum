  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BranchChoice
  dialogueManager: {fileID: 1166681350}
  choiceADialogue:
  - speaker: Mouse
    portraitName: Mouse_Excited
    text: 'Absolutely! So she can be in peak shape when she performs infront of directors. '
    backgroundName: 
  - speaker: Mouse
    portraitName: Mouse_Excited
    text: ' Higher chance that she will get the role! '
    backgroundName: 
  choiceBDialogue:
  - speaker: Mouse
    portraitName: Mouse_Neutral
    text: You're right. The faster she's done with moving in, the faster she can
      focus all her efforts into practicing.
    backgroundName: 
  - speaker: Mouse
    portraitName: Mouse_Sad
    text: Although, I'd be worried whether or not the stress might get to her. She
      might not get the role if she's not in peak shape.
    backgroundName: 
  choiceAButton: {fileID: 835032129}
  choiceBButton: {fileID: 1237696157}
