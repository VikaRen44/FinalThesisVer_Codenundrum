--- !u!114 &42286795
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 42286794}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 24a696b41c0924b448a55cbfbb0baf54, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BranchChoice
  dialogueManager: {fileID: 1166681350}
  choiceADialogue:
  - speaker: Faith
    portraitName: Faith_cropped
    text: Let's see...
    backgroundName: 
  - speaker: Faith
    portraitName: Faith_cropped
    text: ' I haven''t yet organized majority of the props i got from some of the
      shows i did. As well as, scripts that I will have to practice soon. Which one
      would you like to do next? '
    backgroundName: 
  choiceBDialogue:
  - speaker: Faith
    portraitName: Sad_Faith
    text: You guys will be paid for your hard work.
    backgroundName: 
  - speaker: Faith
    portraitName: Faith_cropped
    text: Other than basic necessities. Some  of those contain props from shows I
      did before.
    backgroundName: 
  - speaker: Faith
    portraitName: Faith_cropped
    text: I keep them for old time's sake.
    backgroundName: 
  - speaker: Mouse
    portraitName: Mouse_Neutral
    text: Why do you keep them?
    backgroundName: 
  - speaker: Faith
    portraitName: Confused_Faith
    text: Why not?
    backgroundName: 
  - speaker: Mouse
    portraitName: Mouse_Sad
    text: They seem like more added weight.
    backgroundName: 
  - speaker: Faith
    portraitName: Surprised_Faith
    text: 'Hey! To you, it may be but to me, they tell me how far I have come. '
    backgroundName: 
  - speaker: Faith
    portraitName: Sad_Faith
    text: I have yet to hit my big shot at the industry.
    backgroundName: 
  - speaker: Faith
    portraitName: Faith_cropped
    text: 'So these small props help me show I have not yet grinded for nothing. '
    backgroundName: 
  - speaker: Mouse
    portraitName: Mouse_Sad
    text: I see. I understand now.
    backgroundName: 
  - speaker: Mouse
    portraitName: Mouse_Neutral
    text: Sorry about that. I did not mean to hurt your feelings.
    backgroundName: 
  - speaker: Mouse
    portraitName: Mouse_Neutral
    text: We'll help you get ready for your big shot. What can we help you next?
    backgroundName: 
  - speaker: Faith
    portraitName: Surprised_Faith
    text: You choose. We can organize next the props i just told y'all or those scripts
      at the corner table. Which one would you like to do next?
    backgroundName: 
  choiceAButton: {fileID: 835032129}
  choiceBButton: {fileID: 1237696157}
  loadSceneAfterChoice: 0
  sceneForChoiceA: 04_True_heap
  sceneForChoiceB: 06_QuickSort
